{
  "name":"undefinedfr/undefined-wp-framework",
  "version": "2.3",
  "type": "wordpress-boilerplate",
  "description": "Mini Framework for Wordpress",
  "license": "GPL-3.0-or-later",
  "require": {
    "timber/timber": "^2.0",
    "vinkla/extended-acf": "^14.2"
  },
  "autoload" : {
    "files": [
      "src/Functions.php"
    ],
    "exclude-from-classmap" : [
      "src/Plugins/",
      "src/Block/",
      "src/PostType/",
      "src/Taxonomy/"
    ],
    "psr-4" : {
      "Undefined\\Core\\" : "src/"
    }
  },
  "authors": [
    {
      "name": "Nicolas RIVIERE",
      "email": "hello@undefined.fr",
      "homepage": "https://www.undefined.fr",
      "role": "Lead Developer"
    }
  ],
  "require-dev": {
    "wp-coding-standards/wpcs": "^3.0",
    "squizlabs/php_codesniffer": "^3.7",
    "phpcompatibility/phpcompatibility-wp": "*",
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
