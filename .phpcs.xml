<?xml version="1.0"?>
<ruleset name="Undefined WP Framework">
	<description>WordPress Coding Standards for Undefined WP Framework</description>

	<!-- Scan only src/ and autoload.php -->
	<file>./src</file>
	<file>./autoload.php</file>

	<!-- Exclude vendor directory -->
	<exclude-pattern>*/vendor/*</exclude-pattern>
	<exclude-pattern>*/node_modules/*</exclude-pattern>

	<!-- Use WordPress Coding Standards -->
	<rule ref="WordPress">
		<!-- Allow short array syntax -->
		<exclude name="Universal.Arrays.DisallowShortArraySyntax"/>
		<!-- File naming: PSR-4 autoloading uses PascalCase -->
		<exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
		<exclude name="WordPress.Files.FileName.NotHyphenatedLowercase"/>
	</rule>

	<!-- PHP Compatibility -->
	<config name="testVersion" value="8.0-"/>
	<rule ref="PHPCompatibilityWP"/>

	<!-- WordPress minimum version -->
	<config name="minimum_wp_version" value="6.0"/>

	<!-- Allow . in hook names (namespaced hooks) -->
	<rule ref="WordPress.NamingConventions.ValidHookName">
		<properties>
			<property name="additionalWordDelimiters" value="."/>
		</properties>
	</rule>

	<!-- Text domain -->
	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array">
				<element value="undefined-wp-framework"/>
			</property>
		</properties>
	</rule>

	<!-- Show colors and progress -->
	<arg name="colors"/>
	<arg value="sp"/>

	<!-- Use PSR-12 indentation (tabs) -->
	<arg name="tab-width" value="4"/>
</ruleset>
